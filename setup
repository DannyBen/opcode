#!/usr/bin/env bash
set -euo pipefail

echo Initializing installer...
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
cd "$tmpdir"
wget -q https://github.com/DannyBen/ssi/releases/latest/download/ssi
chmod +x ssi

./ssi log info Installing opcode
./ssi install bin https://github.com/DannyBen/opcode/releases/latest/download/op
./ssi install man https://raw.githubusercontent.com/DannyBen/opcode/master/doc/op.1
printf "complete -C 'op --completion' op\n" | ./ssi install completion --shell bash --name op -

./ssi log info "op --version : $(op --version)"
