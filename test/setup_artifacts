#!/usr/bin/env bash
set -e

if [[ ! -f "/usr/local/bin/op" ]]; then
  echo "ERROR: File not found /usr/local/bin/op"
  exit 1
fi

found_completion=false
for dir in \
  "/usr/local/share/bash-completion/completions" \
  "/usr/share/bash-completion/completions" \
  "/usr/local/etc/bash_completion.d" \
  "/etc/bash_completion.d" \
  "/opt/homebrew/share/bash-completion/completions" \
  "/opt/homebrew/etc/bash_completion.d"
do
  if [[ -f "$dir/op" ]]; then
    found_completion=true
    break
  fi
done

if [[ "$found_completion" != "true" ]]; then
  echo "ERROR: Cannot find completion file for op"
  exit 1
fi

if [[ ! -f "/usr/local/share/man/man1/op.1" ]]; then
  echo "ERROR: File not found /usr/local/share/man/man1/op.1"
  exit 1
fi

echo "Setup artifacts are OK"
