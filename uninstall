#!/usr/bin/env bash
set -euo pipefail

# === Setup SSI ===

echo "Initializing installer..."
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
cd "$tmpdir"
export PATH="$tmpdir:$PATH"

if command -v wget >/dev/null 2>&1; then
  wget -q -O ssi https://github.com/DannyBen/ssi/releases/download/v0.1.3/ssi
elif command -v curl >/dev/null 2>&1; then
  curl -fsSL https://github.com/DannyBen/ssi/releases/download/v0.1.3/ssi -o ssi
else
  echo "Error: please install wget or curl, then try again" >&2
  exit 1
fi
chmod +x ssi

# === Uninstall ===

ssi log info Uninstalling opcode
ssi uninstall bin op
ssi uninstall man op.1
ssi uninstall completion op
